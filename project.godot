; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Witpass"
config/version="Beta"
run/main_scene="res://Scenes/intro.tscn"
config/use_custom_user_dir=true
config/quit_on_go_back=false
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

Global="*res://global.tscn"
Questions="*res://Scripts/questions.gd"

[debug]

file_logging/log_path="user://logs/witpass.log"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=540
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/handheld/orientation=1
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/SystemBarColorChanger/plugin.cfg", "res://addons/ToastPlugin/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "teal",
"res://Resources/": "red",
"res://Resources/Shaders/": "purple",
"res://Scenes/": "orange",
"res://Scripts/": "yellow",
"res://addons/": "gray"
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[internationalization]

locale/translations=PackedStringArray("res://assets/localization/app_ui_localization/Witpass Localization.ar.translation", "res://assets/localization/app_ui_localization/Witpass Localization.de.translation", "res://assets/localization/app_ui_localization/Witpass Localization.en.translation", "res://assets/localization/app_ui_localization/Witpass Localization.es.translation", "res://assets/localization/app_ui_localization/Witpass Localization.fr.translation", "res://assets/localization/app_ui_localization/Witpass Localization.hi.translation", "res://assets/localization/app_ui_localization/Witpass Localization.pt.translation", "res://assets/localization/app_ui_localization/Witpass Localization.ru.translation", "res://assets/localization/app_ui_localization/Witpass Localization.zh.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.ar.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.de.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.en.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.es.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.fr.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.hi.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.pt.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.ru.translation", "res://assets/localization/questions_localization/Witpss Questions Localization.zh.translation")

[physics]

common/physics_ticks_per_second=30

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
2d/snap/snap_2d_transforms_to_pixel=true
